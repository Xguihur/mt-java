<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  namespace 必须和 Mapper 接口的全路径完全一致，
  MyBatis 靠它把 XML 里的 SQL 和接口方法关联起来。
-->
<mapper namespace="com.mtjava.smsadminlite.mapper.UserMapper">

    <!--
      resultType 写模型类的全类名，MyBatis 会把查询结果自动映射到 User 对象。
      因为 application.yml 开了 map-underscore-to-camel-case，
      created_at 列会自动对应 createdAt 字段，不需要额外配置。
    -->
    <select id="selectAll" resultType="com.mtjava.smsadminlite.model.User">
        SELECT id, name, phone, created_at
        FROM users
        ORDER BY id
    </select>

    <select id="selectById" resultType="com.mtjava.smsadminlite.model.User">
        SELECT id, name, phone, created_at
        FROM users
        WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultType="com.mtjava.smsadminlite.model.User">
        SELECT id, name, phone, created_at
        FROM users
        WHERE phone = #{phone}
        LIMIT 1
    </select>

    <!--
      useGeneratedKeys="true"  ：告诉 MyBatis 使用数据库的自增主键。
      keyProperty="id"         ：把生成的主键值回填到传入 User 对象的 id 字段。
      这样 insert 执行后，你手里的 user.getId() 就有值了。
    -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (name, phone, created_at)
        VALUES (#{name}, #{phone}, #{createdAt})
    </insert>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM users
    </select>

</mapper>
